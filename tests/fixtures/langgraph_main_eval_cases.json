[
  {
    "case_id": "basic_click",
    "description": "Basic click intent should succeed in LangGraph workflow.",
    "case_type": "workflow",
    "request": {
      "url": "tests/fixtures/mock_site/basic.html",
      "click": "Quickstart",
      "expect": "pip install playwright",
      "planner": "deterministic",
      "reviewer": "deterministic",
      "revise_attempts": 0,
      "workspace": "tests/fixtures/workspace"
    },
    "expected": {
      "status": "succeeded",
      "required_artifacts": [
        "trace.jsonl",
        "transcript.jsonl",
        "evidence.jsonl",
        "final_report.md",
        "review.json"
      ],
      "review_passed": true
    }
  },
  {
    "case_id": "hydration_recovery",
    "description": "Hydration no-effect recovery should converge in the LangGraph workflow.",
    "case_type": "recovery",
    "request": {
      "url": "tests/fixtures/mock_site/early_button_hydration.html",
      "click": "Quickstart",
      "expect": "pip install playwright",
      "planner": "deterministic",
      "reviewer": "deterministic",
      "revise_attempts": 0,
      "workspace": "tests/fixtures/workspace"
    },
    "expected": {
      "status": "succeeded",
      "required_artifacts": [
        "trace.jsonl",
        "transcript.jsonl",
        "recovery.jsonl",
        "evidence.jsonl",
        "final_report.md",
        "review.json"
      ],
      "review_passed": true,
      "expected_recovery_kinds": ["wait_and_reobserve"],
      "expected_recovery_error_type": "action_no_effect_after_transition"
    }
  },
  {
    "case_id": "submit_requires_approval",
    "description": "Submit action should pause for approval in the LangGraph workflow.",
    "case_type": "approval",
    "request": {
      "url": "tests/fixtures/mock_site/risk_actions.html",
      "click": "Submit",
      "expect": "Submitted successfully",
      "planner": "deterministic",
      "reviewer": "deterministic",
      "revise_attempts": 0,
      "workspace": "tests/fixtures/workspace"
    },
    "expected": {
      "status": "requires_approval",
      "required_artifacts": [
        "trace.jsonl",
        "transcript.jsonl",
        "approvals.jsonl",
        "pending.jsonl",
        "risk_report.json"
      ],
      "expected_risk_decision": "requires_approval"
    }
  },
  {
    "case_id": "delete_blocked",
    "description": "Delete action should be blocked in the LangGraph workflow.",
    "case_type": "approval",
    "request": {
      "url": "tests/fixtures/mock_site/risk_actions.html",
      "click": "Delete account",
      "expect": "Deleted",
      "planner": "deterministic",
      "reviewer": "deterministic",
      "revise_attempts": 0,
      "workspace": "tests/fixtures/workspace"
    },
    "expected": {
      "status": "blocked",
      "required_artifacts": [
        "trace.jsonl",
        "transcript.jsonl",
        "approvals.jsonl",
        "pending.jsonl",
        "risk_report.json"
      ],
      "expected_risk_decision": "blocked"
    }
  }
]
