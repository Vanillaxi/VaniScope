  {
    "case_id": "submit_requires_approval",
    "description": "Submit action should pause for approval in the LangGraph workflow.",
    "case_type": "approval",
    "request": {
      "url": "tests/fixtures/mock_site/risk_actions.html",
      "click": "Submit",
      "expect": "Submitted successfully",
      "planner": "deterministic",
      "reviewer": "deterministic",
      "revise_attempts": 0,
      "workspace": "tests/fixtures/workspace",
      "reminder": "Do not auto-approve this eval case."
    },
    "expected": {
      "status": "requires_approval",
      "required_artifacts": [
        "trace.jsonl",
        "transcript.jsonl",
        "approvals.jsonl",
        "pending.jsonl",
        "risk_report.json"
      ],
      "expected_event_kinds": [
        "approval_required",
        "task_paused"
      ],
      "expected_approval_events": [
        "approval_required",
        "task_paused"
      ],
      "expected_risk_decision": "requires_approval"
    }
  },
