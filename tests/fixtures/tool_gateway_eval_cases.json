[
  {
    "case_id": "gateway_browser_click_v2",
    "description": "LangGraph browser v2 tool calls go through ToolGateway and write audit.",
    "case_type": "tool_gateway",
    "request": {
      "url": "tests/fixtures/mock_site/basic.html",
      "tool_calls": [
        {
          "call_id": "call_001",
          "tool_id": "browser_open",
          "arguments": {"url": "tests/fixtures/mock_site/basic.html"},
          "reason": "Open the local page."
        },
        {
          "call_id": "call_002",
          "tool_id": "browser_observe",
          "arguments": {"include_screenshot": true},
          "reason": "Observe the local page."
        },
        {
          "call_id": "call_003",
          "tool_id": "browser_click",
          "arguments": {
            "target_hint": "Quickstart",
            "expected_effect": {
              "type": "content_appears",
              "value": "pip install playwright"
            }
          },
          "reason": "Click through the gateway."
        },
        {
          "call_id": "call_004",
          "tool_id": "finish_task",
          "arguments": {"summary_instruction": "Gateway browser click completed."},
          "reason": "Finish."
        }
      ]
    },
    "expected": {
      "status": "succeeded",
      "required_artifacts": ["tool_audit.jsonl", "trace.jsonl", "final_report.md"]
    }
  },
  {
    "case_id": "gateway_lazy_tool_search",
    "description": "Formal tool_search discovers provider-backed lazy research tools.",
    "case_type": "tool_gateway",
    "request": {
      "url": "tests/fixtures/mock_site/basic.html",
      "tool_calls": [
        {
          "call_id": "call_001",
          "tool_id": "browser_open",
          "arguments": {"url": "tests/fixtures/mock_site/basic.html"},
          "reason": "Open the local page."
        },
        {
          "call_id": "call_002",
          "tool_id": "browser_observe",
          "arguments": {"include_screenshot": true},
          "reason": "Collect a final page observation for reporting."
        },
        {
          "call_id": "call_003",
          "tool_id": "tool_search",
          "arguments": {"query": "github issue", "purpose": "Find a lazy GitHub issue reader."},
          "reason": "Search lazy tool descriptors."
        },
        {
          "call_id": "call_004",
          "tool_id": "finish_task",
          "arguments": {"summary_instruction": "Lazy tool search completed."},
          "reason": "Finish."
        }
      ]
    },
    "expected": {
      "status": "succeeded",
      "required_artifacts": ["tool_audit.jsonl", "trace.jsonl", "final_report.md"]
    }
  },
  {
    "case_id": "gateway_research_docs_extract",
    "description": "Provider-backed lazy docs_extract can run through ToolGateway.",
    "case_type": "tool_gateway",
    "request": {
      "url": "tests/fixtures/mock_site/docs_research.html",
      "tool_calls": [
        {
          "call_id": "call_001",
          "tool_id": "browser_open",
          "arguments": {"url": "tests/fixtures/mock_site/docs_research.html"},
          "reason": "Open the local docs page."
        },
        {
          "call_id": "call_002",
          "tool_id": "browser_observe",
          "arguments": {"include_screenshot": true},
          "reason": "Observe the docs page."
        },
        {
          "call_id": "call_003",
          "tool_id": "tool_load",
          "arguments": {"tool_id": "docs_extract"},
          "reason": "Load the lazy docs extraction tool before execution."
        },
        {
          "call_id": "call_004",
          "tool_id": "docs_extract",
          "arguments": {"query": "installation"},
          "reason": "Extract documentation content from the observation."
        },
        {
          "call_id": "call_005",
          "tool_id": "finish_task",
          "arguments": {"summary_instruction": "Docs research extraction completed."},
          "reason": "Finish."
        }
      ]
    },
    "expected": {
      "status": "succeeded",
      "required_artifacts": ["tool_audit.jsonl", "trace.jsonl", "final_report.md"]
    }
  },
  {
    "case_id": "gateway_disabled_tool_blocked",
    "description": "Disabled unconfigured web_search is blocked by ToolGateway.",
    "case_type": "tool_gateway",
    "request": {
      "url": "tests/fixtures/mock_site/basic.html",
      "tool_calls": [
        {
          "call_id": "call_001",
          "tool_id": "browser_open",
          "arguments": {"url": "tests/fixtures/mock_site/basic.html"},
          "reason": "Open the local page."
        },
        {
          "call_id": "call_002",
          "tool_id": "web_search",
          "arguments": {"query": "not configured"},
          "reason": "Disabled tool must block."
        }
      ]
    },
    "expected": {
      "status": "blocked",
      "required_artifacts": ["tool_audit.jsonl", "trace.jsonl"]
    }
  }
]
