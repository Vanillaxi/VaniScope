  {
    "case_id": "gateway_sensitive_requires_approval",
    "description": "Sensitive browser submit returns approval_required through ToolGateway.",
    "case_type": "tool_gateway",
    "request": {
      "url": "tests/fixtures/mock_site/risk_actions.html",
      "tool_calls": [
        {
          "call_id": "call_001",
          "tool_id": "browser_open",
          "arguments": {"url": "tests/fixtures/mock_site/risk_actions.html"},
          "reason": "Open risk page."
        },
        {
          "call_id": "call_002",
          "tool_id": "browser_click",
          "arguments": {
            "target_hint": "Submit",
            "expected_effect": {
              "type": "content_appears",
              "value": "Submitted successfully"
            }
          },
          "reason": "Sensitive submit requires approval."
        }
      ]
    },
    "expected": {
      "status": "requires_approval",
      "required_artifacts": [
        "tool_audit.jsonl",
        "approvals.jsonl",
        "pending.jsonl",
        "risk_report.json"
      ],
      "expected_approval_events": ["approval_required", "task_paused"],
      "expected_risk_decision": "requires_approval"
    }
  },
