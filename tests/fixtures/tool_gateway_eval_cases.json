[
  {
    "case_id": "gateway_browser_click_v2",
    "description": "LangGraph browser v2 tool calls go through ToolGateway and write audit.",
    "case_type": "tool_gateway",
    "request": {
      "url": "tests/fixtures/mock_site/basic.html",
      "tool_calls": [
        {
          "call_id": "call_001",
          "tool_id": "browser_open",
          "arguments": {"url": "tests/fixtures/mock_site/basic.html"},
          "reason": "Open the local page."
        },
        {
          "call_id": "call_002",
          "tool_id": "browser_observe",
          "arguments": {"include_screenshot": true},
          "reason": "Observe the local page."
        },
        {
          "call_id": "call_003",
          "tool_id": "browser_click",
          "arguments": {
            "target_hint": "Quickstart",
            "expected_effect": {
              "type": "content_appears",
              "value": "pip install playwright"
            }
          },
          "reason": "Click through the gateway."
        },
        {
          "call_id": "call_004",
          "tool_id": "finish_task",
          "arguments": {"summary_instruction": "Gateway browser click completed."},
          "reason": "Finish."
        }
      ]
    },
    "expected": {
      "status": "succeeded",
      "required_artifacts": ["tool_audit.jsonl", "trace.jsonl", "final_report.md"]
    }
  },
  {
