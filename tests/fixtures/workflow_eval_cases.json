[
  {
    "case_id": "basic_click",
    "description": "Basic click intent should succeed in both native and langgraph workflows.",
    "request": {
      "url": "tests/fixtures/mock_site/basic.html",
      "click": "Quickstart",
      "expect": "pip install playwright",
      "planner": "deterministic",
      "reviewer": "deterministic",
      "revise_attempts": 0,
      "workspace": "tests/fixtures/workspace",
      "reminder": "This is a workflow regression eval case."
    },
    "expected": {
      "status": "succeeded",
      "required_artifacts": [
        "trace.jsonl",
        "transcript.jsonl",
        "evidence.jsonl",
        "final_report.md",
        "review.json",
        "compact_context.json"
      ],
      "review_passed": true,
      "min_review_score": 0.8,
      "expected_event_kinds": [
        "task_loaded",
        "plan_built",
        "execution_completed",
        "review_completed",
        "compaction_written"
      ],
      "allow_backend_differences": [
        "workflow_started",
        "workflow_state.json"
      ]
    }
  },
