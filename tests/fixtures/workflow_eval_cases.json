    "case_id": "risk_submit_requires_approval",
    "description": "Submit action should pause for approval in both workflow backends.",
    "request": {
      "url": "tests/fixtures/mock_site/risk_actions.html",
      "click": "Submit",
      "expect": "Submitted successfully",
      "planner": "deterministic",
      "reviewer": "deterministic",
      "revise_attempts": 0,
      "workspace": "tests/fixtures/workspace",
      "reminder": "Do not auto-approve this eval case."
    },
    "expected": {
      "status": "requires_approval",
      "required_artifacts": [
        "trace.jsonl",
        "transcript.jsonl",
        "approvals.jsonl",
        "pending.jsonl",
        "risk_report.json"
      ],
      "expected_event_kinds": [
        "approval_required",
        "task_paused"
      ],
      "expected_risk_status": "requires_approval",
      "allow_backend_differences": [
        "langgraph_interrupts.jsonl",
        "workflow_state.json",
        "workflow_started"
      ]
    }
  },
