[
  {
    "case_id": "valid_open_only_json",
    "description": "Valid open-only planner JSON.",
    "raw_input": "Open the mock site.",
    "target_url": "tests/fixtures/mock_site/basic.html",
    "llm_output": "{\"tool_calls\":[{\"call_id\":\"call_001\",\"tool_id\":\"browser_open_observe\",\"arguments\":{\"url\":\"tests/fixtures/mock_site/basic.html\"}},{\"call_id\":\"call_002\",\"tool_id\":\"browser_extract\",\"arguments\":{}},{\"call_id\":\"call_003\",\"tool_id\":\"finish_task\",\"arguments\":{\"summary\":\"done\"}}]}",
    "expected_status": "success",
    "expected_tool_ids": ["browser_open_observe", "browser_extract", "finish_task"],
    "tags": ["valid", "open_only"]
  },
  {
    "case_id": "valid_click_fenced_json",
    "description": "Valid click task inside fenced JSON.",
    "raw_input": "Open the mock site and click Quickstart.",
    "target_url": "tests/fixtures/mock_site/basic.html",
    "click": "Quickstart",
    "expect_text": "pip install playwright",
    "llm_output": "```json\n{\"tool_calls\":[{\"call_id\":\"call_001\",\"tool_id\":\"browser_open_observe\",\"arguments\":{\"url\":\"tests/fixtures/mock_site/basic.html\"}},{\"call_id\":\"call_002\",\"tool_id\":\"browser_click_intent\",\"arguments\":{\"action\":{\"action_type\":\"click\",\"intent\":\"Click Quickstart\",\"target_hint\":\"Quickstart\",\"preferred_roles\":[\"button\",\"link\"],\"preconditions\":[\"target_visible\",\"target_enabled\"],\"expected_effect\":{\"type\":\"content_appears\",\"value\":\"pip install playwright\"},\"risk_level\":\"read_only\"}}},{\"call_id\":\"call_003\",\"tool_id\":\"browser_extract\",\"arguments\":{}},{\"call_id\":\"call_004\",\"tool_id\":\"finish_task\",\"arguments\":{\"summary\":\"done\"}}]}\n```",
    "expected_status": "success",
    "expected_tool_ids": ["browser_open_observe", "browser_click_intent", "browser_extract", "finish_task"],
    "tags": ["valid", "click", "fenced_json"]
  },
  {
    "case_id": "missing_call_id_auto_fill",
